# Free local LLM — no paid API keys required
# Best quality: install Ollama from https://ollama.com then run: ollama pull llama3.2

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# Optional HydraDB cloud memory (falls back to local store if not configured)
HYDRA_DB_API_KEY=your-hydradb-api-key-here
HYDRA_TENANT_ID=your-tenant-id-here
HYDRA_SUB_TENANT_ID=demo-session-001
THREAD_SESSION_ID=demo-session-001

# Server
HOST=127.0.0.1
PORT=8070
